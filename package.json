{
	"name": "storefrontdemo",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@9.10.0+sha512.73a29afa36a0d092ece5271de5177ecbf8318d454ecd701343131b8ebc0c1a91c487da46ab77c8e596d6acf1461e3594ced4becedf8921b074fbd8653ed7051c",
	"pnpm": {
		"overrides": {
			"esbuild": "0.28.1",
			"yaml": "2.8.3"
		},
		"patchedDependencies": {
			"wrangler@4.100.0": "patches/wrangler@4.100.0.patch"
		}
	},
	"scripts": {
		"dev:ci": "doppler run pnpm openapi-ts && doppler run astro dev",
		"dev": "astro dev",
		"start": "astro dev",
		"build:ci": "pnpm openapi-ts && pnpm astro build",
		"build": "pnpm astro build",
		"deploy:workers": "pnpm build && wrangler deploy --config dist/server/wrangler.json",
		"astro": "astro",
		"lint": "astro sync && run-s --continue-on-error lint:*",
		"lint:biome": "biome lint src",
		"lint:astro": "astro check",
		"lint:types": "tsc -b",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"format": "run-s --continue-on-error format:*",
		"format:biome": "biome check . --apply",
		"format:prettier": "prettier . --cache --write --list-different"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@biomejs/biome": "^2.5.0",
		"@hey-api/openapi-ts": "^0.98.2",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-jsdoc": "^1.8.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-tsconfig-paths": "^1.4.1",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.7.0",
		"@astrojs/react": "^5.0.7",
		"@astrojs/tailwind": "6.0.2",
		"@fontsource-variable/inter": "5.2.8",
		"@hey-api/client-fetch": "^0.13.1",
		"@playwright/test": "^1.60.0",
		"@sentry/astro": "^10.57.0",
		"@tailwindcss/typography": "0.5.20",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-query-devtools": "^5.101.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"astro": "^6.4.6",
		"astro-icon": "^1.1.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"stripe": "22.2.1",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "^3.4.19",
		"tailwindcss-animate": "^1.0.7",
		"type-fest": "^5.7.0",
		"wrangler": "^4.100.0",
		"zod": "4.4.3"
	}
}
