{
	"extends": "astro/tsconfigs/strictest",
	"include": ["src", "astro.config.ts", "openapi-ts.config.ts"],
	"compilerOptions": {
		"exactOptionalPropertyTypes": false,
		"ignoreDeprecations": "6.0",
